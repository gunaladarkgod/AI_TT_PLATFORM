# =============================================================================
# ClearML 与本后端集成 —— 按顺序做完即可（REST API 需要合法凭证）
# =============================================================================
# 1) 登录 https://app.clear.ml ，进入当前 Workspace。
# 2) 在「API Credentials」区域点击 「+ Create new credentials」，输入标签后确定。
#    弹窗会给出两行：**access_key** 与 **secret_key**（Secret 往往只显示这一次，请立刻复制保存）。
#    若列表里只看到一列 KEY：先用下面两行之一填空密码试跑；仍失败则必须以步骤 2 的「成对凭证」为准。
# 3) 复制本文件为 env.clearml.local（已在 .gitignore），填入下面两行密钥。
# 4) 启动后端前加载环境变量任选其一：
#    • bash:  set -a && source .../backend/env.clearml.local && set +a && cd backend && mvn spring-boot:run
#    • 脚本:  bash backend/run-backend-dev.sh
#    • VS Code: 运行配置 「Backend WebApplication (env.clearml.local)」自动读取 env.clearml.local
# =============================================================================

CLEARML_ENABLED=true
CLEARML_API_HOST=https://api.clear.ml
CLEARML_WEB_HOST=https://app.clear.ml

CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=

# 可选：只显示项目名称包含该子串的任务；留空则不过滤
# CLEARML_PROJECT_NAME_CONTAINS=
